# Public site URL (used in canonicals, sitemap, OG tags). Override per environment.
NEXT_PUBLIC_SITE_URL=https://hairtransplantsource.com

# Analytics dashboard auth. If unset, the dashboard is open — set this in production.
ANALYTICS_TOKEN=

# Deploy hook (Vercel/Netlify). The publish cron POSTs here after committing
# scheduled-article frontmatter changes so the site rebuilds on schedule.
DEPLOY_HOOK_URL=
